<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!-- NameNode storage path -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>file:///hadoop/dfs/name</value>
  </property>

  <!-- DataNode storage path -->
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///hadoop/dfs/data</value>
  </property>

  <!-- Replication factor (1 for single datanode) -->
  <property>
    <name>dfs.replication</name>
    <value>3</value>
  </property>

  <!-- Disable permission checks for development -->
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>

  <!-- Block size: 128MB -->
  <property>
    <name>dfs.blocksize</name>
    <value>134217728</value>
  </property>

  <!-- Number of NameNode handler threads -->
  <property>
    <name>dfs.namenode.handler.count</name>
    <value>10</value>
  </property>

  <!-- Disable hostname check for DataNode registration -->
  <property>
    <name>dfs.namenode.datanode.registration.ip-hostname-check</name>
    <value>false</value>
  </property>

  <!-- Enable WebHDFS REST API -->
  <property>
    <name>dfs.webhdfs.enabled</name>
    <value>true</value>
  </property>
</configuration>
